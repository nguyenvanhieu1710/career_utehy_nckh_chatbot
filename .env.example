# MongoDB Configuration
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=career_db

# PostgreSQL Configuration
DATABASE_URL=postgresql+asyncpg://postgres:12345678@localhost:5432/career_utehy_db

# Gemini Configuration
